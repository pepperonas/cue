# ---- cue configuration ----
# Copy to .env and fill in. Never commit .env.

# Argon2id hash of your single login password.
# Generate with:  python scripts/gen_password_hash.py
#
# IMPORTANT (docker compose): compose interpolates env_file values, so every
# literal '$' in the Argon2 hash must be doubled to '$$', e.g.
#   APP_PASSWORD_HASH=$$argon2id$$v=19$$m=65536,t=3,p=4$$<salt>$$<digest>
# Running uvicorn directly (no compose) uses the hash verbatim — do NOT double.
APP_PASSWORD_HASH=

# Secret used to sign session + CSRF tokens. Generate with:
#   openssl rand -hex 32
SECRET_KEY=

# Session lifetime in seconds (default = 30 days = "remember me").
SESSION_MAX_AGE=2592000

# Cookie Secure flag. MUST be true in production (TLS terminated by the proxy).
# Set false only for local http dev.
COOKIE_SECURE=true

# Browser origin allowed for CSRF/CSP. Match your public URL.
ALLOWED_ORIGIN=https://cue.celox.io

# Trust X-Forwarded-For for the client IP (login rate limiting). Keep true only
# when running behind the trusted reverse proxy, which rewrites the header.
TRUST_PROXY=true

# SQLite database file (persisted on a volume in production).
DB_PATH=data/cue.db

# Directory for uploaded .txt imports.
UPLOAD_DIR=data/uploads

# Directory holding the built frontend (set by the Docker image).
STATIC_DIR=static
