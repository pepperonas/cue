# ---- cue configuration ----
# Copy to .env and fill in. Never commit .env.

# Secret used to sign session + CSRF + OAuth-state tokens. Generate with:
#   openssl rand -hex 32
SECRET_KEY=

# ---- Google OAuth 2.0 (Authorization Code flow) ----
# From Google Cloud Console → APIs & Services → Credentials → OAuth client (Web).
# The secret stays server-side only — never commit it, never ship it to the browser.
#   Authorized JavaScript origins:  https://cue.celox.io
#   Authorized redirect URIs:       https://cue.celox.io/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Access allowlist (comma-separated, case-insensitive). A user may sign in if
# their email is listed OR their email's domain is listed. Leave BOTH empty to
# lock everyone out in production (open access only happens under CUE_DEV=1).
GOOGLE_ALLOWED_EMAILS=
GOOGLE_ALLOWED_DOMAINS=

# On this account's first Google login, any pre-multi-tenant (ownerless) data is
# claimed for them. Set to the original single-user owner's Google email.
OWNER_EMAIL=

# Session lifetime in seconds (default = 30 days = "remember me").
SESSION_MAX_AGE=2592000

# Cookie Secure flag. MUST be true in production (TLS terminated by the proxy).
# Set false only for local http dev.
COOKIE_SECURE=true

# Browser origin allowed for CSRF/CSP; also the base for the OAuth redirect URI.
ALLOWED_ORIGIN=https://cue.celox.io

# Trust X-Forwarded-For for the client IP. Keep true only behind the trusted proxy.
TRUST_PROXY=true

# SQLite database file (persisted on a volume in production).
DB_PATH=data/cue.db

# Directory for uploaded .txt imports.
UPLOAD_DIR=data/uploads

# Directory for persisted prompt image attachments (screenshots). Keep this on
# the data volume in production (e.g. /data/attachments) so they survive rebuilds.
ATTACHMENTS_DIR=data/attachments
# Max attachment size in bytes (default 10 MB).
MAX_ATTACHMENT_BYTES=10485760

# ---- Run engine (Claude Code CLI runner) ----
# Shared secret the Mac runner presents as `Authorization: Bearer <token>`.
# Generate with: openssl rand -hex 32. Must match the runner's .env.
RUNNER_TOKEN=
# Comma-separated absolute base paths (on the runner's machine) under which a
# run's project_path must sit. The run feature is owner-only (OWNER_EMAIL).
ALLOWED_PROJECT_BASES=/Users/martin/claude
# Runs without a runner heartbeat for this many seconds are reaped as failed.
RUN_STALE_TIMEOUT=300

# ---- Prompt capture (log every CLI prompt) ----
# Shared secret for the capture forwarder (Bearer); attributed to OWNER_EMAIL.
# Generate with: openssl rand -hex 32.
CAPTURE_TOKEN=
# Base under which a captured `cwd` becomes a project name (first segment).
# Defaults to the first ALLOWED_PROJECT_BASES entry when unset.
CAPTURE_BASE=/Users/martin/claude

# Directory holding the built frontend (set by the Docker image).
STATIC_DIR=static
