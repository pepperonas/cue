# ---- cue-runner configuration ----
# Copy to .env and fill in. Never commit .env.

# Base URL of the cue backend (https, via the reverse proxy).
CUE_API_URL=https://cue.celox.io

# Shared secret; must match RUNNER_TOKEN in the cue backend .env.
RUNNER_TOKEN=

# Comma-separated absolute base paths a run's project_path must sit under.
ALLOWED_BASES=/Users/martin/claude

# Path to the Claude Code CLI (default: claude on PATH).
CLAUDE_PATH=claude

# Identifier reported when claiming runs.
RUNNER_ID=mac-runner

# Seconds between claim attempts when idle.
POLL_INTERVAL=5
# Concurrent runs (semaphore).
MAX_CONCURRENCY=1
# Seconds between heartbeats (also picks up cancel requests).
HEARTBEAT_INTERVAL=15
# Hard timeout per step in seconds.
RUN_TIMEOUT=1800
